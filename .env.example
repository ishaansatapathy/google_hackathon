# Copy to .env.local and fill in (never commit real keys)
# Google Cloud Console → APIs & Services → Credentials → API key
# Enable "Maps JavaScript API" for this key; restrict by HTTP referrer in production.
VITE_GOOGLE_MAPS_API_KEY=

# Cloud Run only (optional): same key value; injected at runtime via /runtime-env.js — no rebuild needed.
# GOOGLE_MAPS_API_KEY=
