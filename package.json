{
  "name": "targo-hero",
  "private": true,
  "version": "0.0.0",
  "keywords": [
    "google-cloud",
    "google-cloud-run",
    "cloud-build",
    "artifact-registry",
    "google-maps",
    "maps-javascript-api",
    "vite",
    "react",
    "typescript"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --open\" \"node server/ws-server.mjs\" \"node server/sadakbolo-http.mjs\" \"node server/sos-relay.mjs\" \"node server/sos-ws.mjs\"",
    "dev:vite": "vite --open",
    "dev:ws": "node server/ws-server.mjs",
    "build": "tsc -b && vite build",
    "start": "node scripts/cloud-run-serve.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@clerk/clerk-react": "^5.61.4",
    "@clerk/themes": "^2.4.57",
    "@googlemaps/js-api-loader": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "serve-handler": "^6.1.7",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.64.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/youtube": "^0.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
